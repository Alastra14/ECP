# Copia este archivo a .env y ajusta según tu entorno.

# Periodo (mes de cierre) activo — NO hard-codeado en el código.
ECP_ANIO_ACTIVO=2026
ECP_MES_ACTIVO=4

# Base de datos. Por defecto SQLite local (cero configuración).
# Para Postgres (fase de endurecimiento):
# ECP_DATABASE_URL=postgresql+psycopg://usuario:clave@host:5432/ecp

# (Opcional) Carpeta RESULTADO/ con los reportes de referencia, para auto-sembrar
# datos exactos al iniciar (demo / oráculo). En despliegue real no se usa.
# ECP_RESULTADO_DIR=/ruta/a/contruccion ecp/RESULTADO
